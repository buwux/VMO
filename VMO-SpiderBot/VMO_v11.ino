void doDance(){mode=DANCE;sxDance();danceC++;for(int r=0;r<4;r++){svOff(FLH,25);svOff(FLK,-25);svOff(FRH,-25);svOff(FRK,25);svOff(BLH,-25);svOff(BLK,25);svOff(BRH,25);svOff(BRK,-25);d.clearDisplay();int bob=abs(sin(fr*0.3)*6);for(int s=-1;s<=1;s+=2){int x=64+s*22;d.drawLine(x-12,22-bob+4,x,22-bob-6,SH110X_WHITE);d.drawLine(x,22-bob-6,x+12,22-bob+4,SH110X_WHITE);}d.fillRoundRect(50,40-bob,28,12,6,SH110X_WHITE);d.setTextSize(1);d.setTextColor(SH110X_WHITE);d.setCursor(16,56);d.print("** DANCE MODE **");d.display();fr++;delay(150);stand();delay(80);svOff(FLH,-25);svOff(FLK,25);svOff(FRH,25);svOff(FRK,-25);svOff(BLH,25);svOff(BLK,-25);svOff(BRH,-25);svOff(BRK,25);d.clearDisplay();bob=abs(sin(fr*0.3)*6);for(int s=-1;s<=1;s+=2){int x=64+s*22;d.drawLine(x-12,22-bob+4,x,22-bob-6,SH110X_WHITE);d.drawLine(x,22-bob-6,x+12,22-bob+4,SH110X_WHITE);}d.fillRoundRect(50,40-bob,28,12,6,SH110X_WHITE);d.setCursor(16,56);d.print("** DANCE MODE **");d.display();fr++;delay(150);stand();delay(80);}stand();mood=min(mood+20,100);mode=IDLE;}
