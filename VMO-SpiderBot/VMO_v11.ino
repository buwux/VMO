void tMathDiff(){d.clearDisplay();teachHeader("MATH","Diff");if(tPage==0){d.setCursor(4,13);d.print("Differentiation:");d.setCursor(4,24);d.print("finding the gradient");d.setCursor(4,34);d.print("of a curve at any");d.setCursor(4,44);d.print("point dy/dx");for(int x=0;x<40;x++){float fx=sin(x*0.1)*8;d.drawPixel(84+x,40+(int)fx,SH110X_WHITE);}int tx=(tFrame%40);float y1=sin(tx*0.1)*8;d.fillCircle(84+tx,40+(int)y1,2,SH110X_WHITE);}else if(tPage==1){d.setCursor(4,13);d.print("Power Rule:");d.setTextSize(2);d.setCursor(8,28);d.print("nx");d.setTextSize(1);d.setCursor(32,26);d.print("n-1");d.setCursor(4,50);d.print("x^3 -> 3x^2");}else if(tPage==2){d.setCursor(4,13);d.print("Chain Rule:");d.setCursor(4,24);d.print("dy/dx = dy/du x du/dx");d.setCursor(4,38);d.print("(2x+1)^3");d.setCursor(4,48);d.print("= 3(2x+1)^2 x 2");}else if(tPage==3){d.setCursor(4,13);d.print("Stationary points:");d.setCursor(4,24);d.print("dy/dx = 0");for(int x=0;x<100;x++){float fx=-pow((x-50)/20.0,3)+3*(x-50)/20.0;d.drawPixel(14+x,38-(int)(fx*3),SH110X_WHITE);}d.setCursor(30,50);d.print("max");d.setCursor(78,50);d.print("min");d.fillCircle(40,28,2,SH110X_WHITE);d.fillCircle(88,48,2,SH110X_WHITE);}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/4");}
void tMathInteg(){d.clearDisplay();teachHeader("MATH","Integ");if(tPage==0){d.setCursor(4,13);d.print("Integration:");d.setCursor(4,24);d.print("reverse of diff");d.setCursor(4,34);d.print("= area under curve");int fill=tFrame%60;for(int x=0;x<60;x++){float fx=sin(x*0.08)*12;int py=52+(int)fx;d.drawPixel(34+x,py,SH110X_WHITE);if(x<fill)d.drawLine(34+x,52,34+x,py,SH110X_WHITE);}}else if(tPage==1){d.setCursor(4,13);d.print("Power Rule:");d.setCursor(4,26);d.print("x^n -> x^(n+1)/(n+1)");d.setCursor(4,40);d.print("+ C  (constant!)");d.setCursor(4,52);d.print("3x^2 -> x^3 + C");}else if(tPage==2){d.setCursor(4,13);d.print("Definite integral:");d.setCursor(4,24);d.print("Sub limits a to b");d.setCursor(4,36);d.print("F(b) - F(a) = area");d.drawLine(14,52,114,52,SH110X_WHITE);d.setCursor(30,54);d.print("a");d.setCursor(80,54);d.print("b");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tMathMatrix(){d.clearDisplay();teachHeader("MATH","Matrix");if(tPage==0){d.setCursor(4,13);d.print("Matrix = grid of");d.setCursor(4,22);d.print("numbers (rows x cols)");d.drawLine(30,32,30,54,SH110X_WHITE);d.drawLine(28,32,32,32,SH110X_WHITE);d.drawLine(28,54,32,54,SH110X_WHITE);d.drawLine(70,32,70,54,SH110X_WHITE);d.drawLine(68,32,72,32,SH110X_WHITE);d.drawLine(68,54,72,54,SH110X_WHITE);int bk=tFrame%30<15;d.setCursor(36,36);d.print(bk?"a":"2");d.setCursor(54,36);d.print(bk?"b":"3");d.setCursor(36,46);d.print(bk?"c":"1");d.setCursor(54,46);d.print(bk?"d":"4");}else if(tPage==1){d.setCursor(4,13);d.print("Multiply: row x col");d.setCursor(4,26);d.print("[1 2] x [5]");d.setCursor(4,36);d.print("[3 4]   [6]");d.setCursor(4,48);d.print("1x5+2x6=17");d.setCursor(4,56);d.print("3x5+4x6=39");}else if(tPage==2){d.setCursor(4,13);d.print("Determinant (2x2):");d.setCursor(4,26);d.print("det = ad - bc");d.setCursor(4,40);d.print("If det=0: singular!");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tMathVector(){d.clearDisplay();teachHeader("MATH","Vector");if(tPage==0){d.setCursor(4,13);d.print("Vector = magnitude");d.setCursor(4,22);d.print("+ direction");int ax=tFrame%50+20;d.drawLine(20,48,ax,48-(ax-20)/2,SH110X_WHITE);d.fillCircle(ax,48-(ax-20)/2,2,SH110X_WHITE);d.setCursor(4,54);d.print("a = (x,y)");}else if(tPage==1){d.setCursor(4,13);d.print("Magnitude |a|:");d.setCursor(4,26);d.print("|a| = sqrt(x2+y2)");d.drawLine(20,50,70,50,SH110X_WHITE);d.drawLine(70,50,70,30,SH110X_WHITE);d.drawLine(20,50,70,30,SH110X_WHITE);d.setCursor(40,52);d.print("x");d.setCursor(72,38);d.print("y");d.setCursor(34,36);d.print("|a|");}else if(tPage==2){d.setCursor(4,13);d.print("Dot product:");d.setCursor(4,24);d.print("a.b = x1x2 + y1y2");d.setCursor(4,36);d.print("= |a||b| cos(angle)");d.setCursor(4,48);d.print("If a.b=0: perpendic!");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tChemBond(){d.clearDisplay();teachHeader("CHEM","Bond");if(tPage==0){d.setCursor(4,13);d.print("3 types of bonding:");d.setCursor(4,26);d.print("1. Ionic (metal+non)");d.setCursor(4,36);d.print("2. Covalent (sharing)");d.setCursor(4,46);d.print("3. Metallic (sea e-)");}else if(tPage==1){d.setCursor(4,13);d.print("IONIC: e- transfer");int ex=30+tFrame%40;d.drawCircle(30,38,10,SH110X_WHITE);d.setCursor(26,35);d.print("Na");d.drawCircle(90,38,12,SH110X_WHITE);d.setCursor(85,35);d.print("Cl");d.fillCircle(ex,32,2,SH110X_WHITE);d.setCursor(4,54);d.print("Na+ and Cl- attract");}else if(tPage==2){d.setCursor(4,13);d.print("COVALENT: share e-");d.drawCircle(44,36,14,SH110X_WHITE);d.drawCircle(84,36,14,SH110X_WHITE);int bk=tFrame%20<10;if(bk){d.fillCircle(62,33,2,SH110X_WHITE);d.fillCircle(66,39,2,SH110X_WHITE);}d.setCursor(40,33);d.print("O");d.setCursor(80,33);d.print("O");d.setCursor(4,54);d.print("O=O double bond");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tChemMoles(){d.clearDisplay();teachHeader("CHEM","Moles");if(tPage==0){d.setCursor(4,13);d.print("Mole = 6.02x10^23");d.setCursor(4,24);d.print("(Avogadro's number)");int n=tFrame%30;for(int i=0;i<n;i++){int px=20+(i*3)%90,py=38+(i*7)%20;d.fillCircle(px,py,1,SH110X_WHITE);}d.setCursor(4,56);d.print("n = mass / Mr");}else if(tPage==1){d.setCursor(4,13);d.print("Key formulas:");d.setCursor(4,26);d.print("n = mass / Mr");d.setCursor(4,36);d.print("n = vol / 24 (gas)");d.setCursor(4,46);d.print("n = conc x vol(dm3)");}else if(tPage==2){d.setCursor(4,13);d.print("Mole triangle:");d.drawLine(64,22,30,52,SH110X_WHITE);d.drawLine(64,22,98,52,SH110X_WHITE);d.drawLine(30,52,98,52,SH110X_WHITE);d.drawLine(30,38,98,38,SH110X_WHITE);d.setCursor(50,26);d.print("mass");d.setCursor(36,42);d.print("n");d.setCursor(72,42);d.print("Mr");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tChemEq(){d.clearDisplay();teachHeader("CHEM","Equat");if(tPage==0){d.setCursor(4,13);d.print("Balancing equations:");d.setCursor(4,24);d.print("Same atoms each side");d.setCursor(4,36);d.print("H2 + O2 -> H2O");d.setCursor(4,46);d.print("2H2 + O2 -> 2H2O");}else if(tPage==1){d.setCursor(4,13);d.print("State symbols:");d.setCursor(4,26);d.print("(s) solid  (l) liquid");d.setCursor(4,36);d.print("(g) gas  (aq) dissolv");}else if(tPage==2){d.setCursor(4,13);d.print("Ionic equations:");d.setCursor(4,24);d.print("Remove spectators!");d.setCursor(4,36);d.print("NaOH + HCl ->");d.setCursor(4,46);d.print("Net: OH- + H+ -> H2O");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tChemOrg(){d.clearDisplay();teachHeader("CHEM","Organ");if(tPage==0){d.setCursor(4,13);d.print("Organic = carbon");d.setCursor(4,24);d.print("Alkanes: C-C single");d.drawCircle(64,44,6,SH110X_WHITE);d.setCursor(61,41);d.print("C");d.drawLine(64,38,64,30,SH110X_WHITE);d.setCursor(61,24);d.print("H");d.drawLine(64,50,64,56,SH110X_WHITE);d.setCursor(61,56);d.print("H");d.drawLine(58,44,48,44,SH110X_WHITE);d.setCursor(42,41);d.print("H");d.drawLine(70,44,80,44,SH110X_WHITE);d.setCursor(82,41);d.print("H");}else if(tPage==1){d.setCursor(4,13);d.print("Homologous series:");d.setCursor(4,24);d.print("Alk-ANE: CnH2n+2");d.setCursor(4,34);d.print("Alk-ENE: CnH2n (C=C)");d.setCursor(4,44);d.print("Alcohol: CnH2n+1 OH");}else if(tPage==2){d.setCursor(4,13);d.print("Reactions:");d.setCursor(4,24);d.print("Combustion: +O2");d.setCursor(4,34);d.print("Addition: C=C opens");d.setCursor(4,44);d.print("Substitution: swap");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tPhysCircuit(){d.clearDisplay();teachHeader("PHYS","Circu");if(tPage==0){d.setCursor(4,13);d.print("V = IR  (Ohm's law)");d.drawRect(20,26,88,30,SH110X_WHITE);d.drawLine(24,26,24,20,SH110X_WHITE);d.drawLine(28,26,28,22,SH110X_WHITE);for(int i=0;i<5;i++){d.drawLine(50+i*8,56,54+i*8,50,SH110X_WHITE);d.drawLine(54+i*8,50,58+i*8,56,SH110X_WHITE);}int cx=(tFrame*2)%88;d.fillCircle(20+cx,26,2,SH110X_WHITE);}else if(tPage==1){d.setCursor(4,13);d.print("Series: same I");d.setCursor(4,22);d.print("Rtotal = R1+R2+R3");d.setCursor(4,34);d.print("Parallel: same V");d.setCursor(4,42);d.print("1/Rt = 1/R1 + 1/R2");}else if(tPage==2){d.setCursor(4,13);d.print("Power = V x I");d.setCursor(4,24);d.print("P = I^2 x R");d.setCursor(4,34);d.print("P = V^2 / R");d.setCursor(4,46);d.print("Energy = P x t");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tPhysForce(){d.clearDisplay();teachHeader("PHYS","Force");if(tPage==0){d.setCursor(4,13);d.print("F = ma (Newton's 2)");int bx=20+tFrame%60;d.fillRect(bx,38,16,12,SH110X_WHITE);d.drawLine(bx-10,44,bx,44,SH110X_WHITE);d.drawLine(14,50,114,50,SH110X_WHITE);d.setCursor(4,54);d.print("Force -> acceleration");}else if(tPage==1){d.setCursor(4,13);d.print("Newton's Laws:");d.setCursor(4,24);d.print("1. Stay still/moving");d.setCursor(4,33);d.print("   unless forced");d.setCursor(4,42);d.print("2. F = ma");d.setCursor(4,52);d.print("3. Action = reaction");}else if(tPage==2){d.setCursor(4,13);d.print("Weight = m x g");d.setCursor(4,24);d.print("g = 9.81 m/s^2");int fy=24+tFrame%30;d.fillCircle(90,fy,4,SH110X_WHITE);d.drawLine(90,fy+4,90,fy+14,SH110X_WHITE);d.setCursor(4,38);d.print("Friction opposes");d.setCursor(4,48);d.print("motion (always!)");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tPhysWave(){d.clearDisplay();teachHeader("PHYS","Waves");if(tPage==0){d.setCursor(4,13);d.print("v = f x wavelength");for(int x=0;x<120;x++){float fx=sin((x+tFrame*2)*0.08)*10;d.drawPixel(4+x,38+(int)fx,SH110X_WHITE);}d.drawLine(20,52,58,52,SH110X_WHITE);d.setCursor(28,54);d.print("lambda");}else if(tPage==1){d.setCursor(4,13);d.print("Transverse: PERP");for(int x=0;x<50;x++){float fx=sin(x*0.15)*6;d.drawPixel(4+x,30+(int)fx,SH110X_WHITE);}d.setCursor(4,40);d.print("Longitudinal: PARA");d.setCursor(4,50);d.print("EM: Radio>Gamma");}else if(tPage==2){d.setCursor(4,13);d.print("EM Spectrum:");d.setCursor(4,24);d.print("Radio Micro IR");d.setCursor(4,32);d.print("Vis UV Xray Gamma");for(int x=0;x<100;x++){if(tFrame%2==0||x%3!=0)d.drawLine(14+x,44,14+x,50,SH110X_WHITE);}d.setCursor(10,52);d.print("long");d.setCursor(90,52);d.print("short");}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
void tPhysEnergy(){d.clearDisplay();teachHeader("PHYS","Enrgy");if(tPage==0){d.setCursor(4,13);d.print("Energy conserved:");d.setCursor(4,22);d.print("cannot be created");d.setCursor(4,30);d.print("or destroyed");float angle=sin(tFrame*0.08)*0.8;int px=64+sin(angle)*25,py=42+cos(angle)*20;d.drawLine(64,22,px,py,SH110X_WHITE);d.fillCircle(px,py,4,SH110X_WHITE);d.setCursor(4,56);d.print("KE <-> PE");}else if(tPage==1){d.setCursor(4,13);d.print("KE = 0.5 x m x v^2");d.setCursor(4,24);d.print("GPE = m x g x h");d.setCursor(4,36);d.print("Elastic=0.5xkxe^2");d.setCursor(4,48);d.print("Thermal = mcT");}else if(tPage==2){d.setCursor(4,13);d.print("Efficiency:");d.setCursor(4,26);d.print("eff = useful / total");d.setCursor(4,40);d.print("Always < 100%!");int fill=(tFrame%40)+20;d.drawRect(84,24,40,10,SH110X_WHITE);d.fillRect(85,25,fill>38?38:fill,8,SH110X_WHITE);}else tPage=0;d.setCursor(100,56);d.print(tPage+1);d.print("/3");}
