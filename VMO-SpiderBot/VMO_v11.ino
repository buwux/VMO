void tn(int freq,int ms,float vol){int samp=(SR*ms)/1000;int16_t buf[64];int idx=0;size_t w;for(int i=0;i<samp;i++){float t=(float)i/SR;int16_t s=(int16_t)(sin(2.0*M_PI*freq*t)*vol*12000);buf[idx++]=s;buf[idx++]=s;if(idx>=64){i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);idx=0;}}if(idx>0)i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);}
void sl(int ms){int16_t buf[32];memset(buf,0,sizeof(buf));size_t w;int rem=(SR*ms*2)/1000;while(rem>0){int ch=(rem>32)?32:rem;i2s_write(I2S_NUM_0,buf,ch*2,&w,portMAX_DELAY);rem-=ch;}}
void chord(int f1,int f2,int ms,float vol){int samp=(SR*ms)/1000;int16_t buf[64];int idx=0;size_t w;for(int i=0;i<samp;i++){float t=(float)i/SR;float v=sin(2.0*M_PI*f1*t)*0.5+sin(2.0*M_PI*f2*t)*0.5;int16_t s=(int16_t)(v*vol*12000);buf[idx++]=s;buf[idx++]=s;if(idx>=64){i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);idx=0;}}if(idx>0)i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);}
void slide(int f1,int f2,int ms,float vol){int samp=(SR*ms)/1000;int16_t buf[64];int idx=0;size_t w;for(int i=0;i<samp;i++){float t=(float)i/SR;float prog=(float)i/samp;int freq=f1+(f2-f1)*prog;int16_t s=(int16_t)(sin(2.0*M_PI*freq*t)*vol*12000);buf[idx++]=s;buf[idx++]=s;if(idx>=64){i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);idx=0;}}if(idx>0)i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);}
void bab(int syl,int base,float spd){spkOn();int vw[]={700,500,300,600,400,800,350,550};int cn[]={1200,1800,2200,1500,900,2000};for(int s=0;s<syl;s++){int v=vw[esp_random()%8],c=cn[esp_random()%6],p=base+(esp_random()%200)-100;int dur=30+(esp_random()%40);tn(c,(int)(15*spd),0.2);int samples=(SR*(int)(dur*spd))/1000;int16_t buf[64];int idx=0;size_t w;for(int i=0;i<samples;i++){float t=(float)i/SR,prog=(float)i/samples;float env=(prog>0.7)?1.0-(prog-0.7)/0.3:1.0;float val=sin(2.0*M_PI*p*t)*0.4+sin(2.0*M_PI*v*t)*0.2+sin(2.0*M_PI*(p*2)*t)*0.1;int16_t sample=(int16_t)(val*env*12000);buf[idx++]=sample;buf[idx++]=sample;if(idx>=64){i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);idx=0;}}if(idx>0)i2s_write(I2S_NUM_0,buf,idx*2,&w,portMAX_DELAY);if(s<syl-1)sl(10+(esp_random()%30));if(s>0&&s%3==0)sl(40);}spkOff();}
